# Application
APP_ENV=local
HTTP_PORT=8080

# PostgreSQL
DATABASE_URL=postgres://billing:billing@postgres:5432/billing?sslmode=disable

# Queue broker (Redis Streams)
QUEUE_URL=redis://queue:6379/0

# JWT secrets — CHANGE THESE in any non-local environment.
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Password hashing cost (bcrypt)
BCRYPT_COST=12

# Auth rate limiting
AUTH_RATE_LIMIT=10
AUTH_RATE_LIMIT_WINDOW=1m

# Background workers
WORKER_CONCURRENCY=4
JOB_MAX_ATTEMPTS=5

# Scheduler
SCHEDULER_INTERVAL=60s

# CORS (comma-separated origins, or *)
CORS_ALLOWED_ORIGINS=*

# Bootstrap admin (created on startup if it does not exist)
ADMIN_EMAIL=admin@billing.local
ADMIN_PASSWORD=admin12345
