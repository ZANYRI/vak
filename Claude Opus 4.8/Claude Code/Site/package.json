{
  "name": "recipe-app",
  "version": "1.0.0",
  "private": true,
  "description": "Savora — a bilingual (EN/RU) recipe website built with Next.js 16",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "motion": "12.40.0",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  }
}
