# Public site URL (used for SEO canonical / Open Graph absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated list of allowed image hosts (informational; remotePatterns
# are configured statically in next.config.ts)
NEXT_PUBLIC_IMAGE_HOSTS=images.unsplash.com,images.pexels.com,upload.wikimedia.org
