APP_ENV=local
HTTP_PORT=8080
METRICS_PORT=9090

DATABASE_URL=postgres://billing:billing@postgres:5432/billing?sslmode=disable
MIGRATIONS_PATH=migrations

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

QUEUE_URL=nats://queue:4222
QUEUE_STREAM=BILLING
QUEUE_CONSUMER_API=api
QUEUE_CONSUMER_WORKER=worker

SCHEDULER_INTERVAL=*/1 * * * *

LOG_LEVEL=info
