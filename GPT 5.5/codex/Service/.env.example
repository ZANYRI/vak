APP_ENV=local
HTTP_PORT=8080
DATABASE_URL=postgres://billing:billing@localhost:5432/billing?sslmode=disable
QUEUE_URL=nats://localhost:4222
# Use unique secrets of at least 32 characters outside local development.
JWT_ACCESS_SECRET=local-development-access-secret-change-me-32
JWT_REFRESH_SECRET=local-development-refresh-secret-change-me-32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
CORS_ORIGINS=http://localhost:3000
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=admin-password-change-me
